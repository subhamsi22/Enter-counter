{
    "manifest_version": 3,
    "name": "Enter Counter",
    "version": "1.0",
    "description": "Counts Enter key presses on websites",
    "permissions": [
        "storage"
    ],
    "action": {
        "default_popup": "popup.html"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ]
        }
    ]
}